# LLM PROVIDERS
# Cost: $2.50/1M input tokens (~$2.00/script)
GOOGLE_GENAI_API_KEY=your_google_genai_api_key_here

# Claude/Haiku (for script generation) - 99% CHEAPER
# Cost: $0.03/1M input tokens (~$0.00/script)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# IMAGE PROVIDERS
GOOGLE_API_KEY=your_api_key_here

# Google Cloud Text-to-Speech (optional)
# Required only if using provider: 'google-tts'
GOOGLE_TTS_API_KEY=your_google_tts_api_key_here

# ElevenLabs TTS (optional)
# Required only if using provider: 'elevenlabs'
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
